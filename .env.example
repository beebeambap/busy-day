# busy-day environment variables
# Copy to .env and fill in real values. .env is gitignored.

# ── Supabase (project: busy-day, region: ap-northeast-2) ─────
SUPABASE_URL=https://diqxldieduslrpkjrguc.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...                # server-only, never expose
